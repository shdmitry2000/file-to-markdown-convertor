# File-to-Markdown Convertor Configuration
# Copy this file to .env and adjust values as needed

# ── Environment (auto-detected if not set) ─────────────────────
# Options: 'standalone', 'docker', 'kubernetes'
# ENVIRONMENT=standalone

# ── File Paths ─────────────────────────────────────────────────
# Directory for converted markdown files
# Standalone default: ./data/converted_files
# Docker/K8s default: /app/converted_files
# CONVERTED_FILES_DIR=/path/to/converted/files

# Base path for project files (used in Docker/K8s)
# PROJECTS_BASE_PATH=/app/projects

# ── ZeroMQ Configuration ───────────────────────────────────────
# ZeroMQ host for worker communication
# Standalone default: localhost
# Docker/K8s default: api
# ZEROMQ_HOST=localhost

# ZeroMQ ports (usually don't need to change these)
# ZEROMQ_TASK_PORT=5585
# ZEROMQ_RESULT_PORT=5586

# ── Logging ────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# ── Examples for Different Environments ────────────────────────

# Standalone (local development):
# CONVERTED_FILES_DIR=./data/converted_files
# ZEROMQ_HOST=localhost

# Docker:
# CONVERTED_FILES_DIR=/app/converted_files
# ZEROMQ_HOST=api
# DOCKER_CONTAINER=true

# Kubernetes:
# CONVERTED_FILES_DIR=/app/converted_files
# ZEROMQ_HOST=api
# PROJECTS_BASE_PATH=/app/projects
